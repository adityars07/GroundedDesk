# ============================================================
# GroundedDesk — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://gd_user:gd_local_password@localhost:5432/groundeddesk?schema=public"

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_HOST="localhost"
QDRANT_PORT=6333

# ── Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_CHAT_MODEL="models/gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="models/gemini-embedding-001"

# ── LLM Settings ─────────────────────────────────────────────
VECTOR_SIZE=768

# ── Cohere Reranker ──────────────────────────────────────────
# Required for Phase 20 advanced reranking. Falls back to cosine if empty.
COHERE_API_KEY=""

# ── Stripe Billing ───────────────────────────────────────────
# Required for Phase 18 metered billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="7d"

# NextAuth (for apps/web)
AUTH_SECRET="change-this-to-a-secure-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Langfuse (Observability) ────────────────────────────────
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# ── App ──────────────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3000
WIDGET_PORT=3001
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── Storage (local dev uses filesystem) ─────────────────────
STORAGE_TYPE="local"
STORAGE_LOCAL_PATH="./uploads"
# For production (Cloudflare R2 / S3):
# STORAGE_TYPE="s3"
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""
